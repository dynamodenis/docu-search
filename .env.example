# =========================================================
# docu-search environment
# Copy to .env and fill in real values. Never commit .env.
# =========================================================

# ---- Qdrant Cloud ----------------------------------------
QDRANT_URL=https://your-cluster-id.qdrant.io
QDRANT_API_KEY=your-qdrant-api-key
QDRANT_COLLECTION=docs_search

# ---- OpenRouter (single gateway for all LLM models) ------
# Get a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-...
# Default model used for answer generation + tool-routing.
# Must be a model that supports tool / function calling.
#
# Cheap & good-enough (recommended — retrieval does the heavy lifting):
#   anthropic/claude-haiku-4.5     ← default
#   openai/gpt-4o-mini
#   google/gemini-2.5-flash
#
# Frontier (only if cheap models struggle with your domain):
#   anthropic/claude-sonnet-4.5
#   openai/gpt-4o
#   google/gemini-2.5-pro
OPENROUTER_MODEL=anthropic/claude-haiku-4.5
# Optional attribution headers (shown in OpenRouter dashboard)
OPENROUTER_SITE_URL=https://github.com/your-handle/docu-search
OPENROUTER_APP_NAME=docu-search

# ---- Tavily (web search) ---------------------------------
# Get a key at https://tavily.com
TAVILY_API_KEY=tvly-...

# ---- Backend ---------------------------------------------
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
# CORS origins the backend accepts (comma-separated).
# Add your Streamlit / Vercel URL once deployed.
CORS_ORIGINS=http://localhost:8501,http://127.0.0.1:8501
# Default max pages when a caller does not specify. Not a hard ceiling —
# callers can pass max_pages up to 10000 in the request body.
INGEST_MAX_PAGES=1000
# Shared secret for admin endpoints like POST /admin/finalize.
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
ADMIN_TOKEN=change-me-to-a-long-random-string
# User-Agent the scraper sends.
SCRAPER_USER_AGENT=docu-search-bot/0.1 (+https://github.com/your-handle/docu-search)

# ---- Frontend (Streamlit) --------------------------------
# Where the Streamlit app should reach the backend.
BACKEND_URL=http://localhost:8000
